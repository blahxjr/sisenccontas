# ─── ATENÇÃO: Nunca versione o arquivo .env ───────────────────────────────
# Copie este arquivo como .env e preencha os valores.
# O arquivo .env está no .gitignore e NUNCA deve ser commitado.

# ── Banco de dados ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://encerradigital:SENHA_AQUI@localhost:5432/encerradigital_dev"

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── MinIO / S3 ──────────────────────────────────────────────────────────────
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_USE_SSL="false"
MINIO_ACCESS_KEY="CHAVE_AQUI"
MINIO_SECRET_KEY="SEGREDO_AQUI"
MINIO_BUCKET_TERMOS="termos-encerramento"

# ── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET="SEGREDO_JWT_MUITO_FORTE_AQUI"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Criptografia de dados sensíveis ─────────────────────────────────────────
ENCRYPTION_KEY="CHAVE_AES_256_AQUI"

# ── Aplicação ───────────────────────────────────────────────────────────────
NODE_ENV="development"
BACKEND_PORT="3333"
FRONTEND_CLIENTE_URL="http://localhost:3000"
FRONTEND_INTERNO_URL="http://localhost:3001"

# ── OIDC/SSO (módulo interno — configurar conforme IdP do banco) ─────────────
OIDC_ISSUER_URL="https://idp.banco.com.br"
OIDC_CLIENT_ID="encerradigital-interno"
OIDC_CLIENT_SECRET="SEGREDO_OIDC_AQUI"
