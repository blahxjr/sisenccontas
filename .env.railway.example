# ════════════════════════════════════════════════════════════════════════════
# Template de variáveis de ambiente para deploy no Railway — EncerraDigital
# Configure cada variável no dashboard do Railway (Settings → Variables)
# NUNCA commite este arquivo com valores reais preenchidos
#
# CONFIGURAÇÃO DO PROJETO NO RAILWAY (fazer 1x por serviço):
# 1. Criar projeto → conectar repositório GitHub (blahxjr/sisenccontas)
# 2. Adicionar plugin PostgreSQL → DATABASE_URL gerada automaticamente
# 3. Adicionar plugin Redis      → REDIS_URL gerada automaticamente
# 4. Criar 3 serviços Web:
#
#    Serviço         | Root Dir | Config File Path
#    ————————————————|——————————|————————————————————————————————
#    backend         |    /     | infra/railway/backend.toml
#    frontend-cliente|    /     | infra/railway/frontend-cliente.toml
#    frontend-interno|    /     | infra/railway/frontend-interno.toml
#
#    Settings → Config As Code → Path → (preencher conforme tabela acima)
# ════════════════════════════════════════════════════════════════════════════

# ── SERVIÇO: backend ─────────────────────────────────────────────────────────
# Build:  pnpm install --frozen-lockfile && pnpm --filter ./backend exec prisma generate && pnpm --filter ./backend build
# Start:  pnpm --filter ./backend exec node dist/main
# Health: GET /api/saude

NODE_ENV=production

# Gerado automaticamente pelo plugin PostgreSQL do Railway:
DATABASE_URL=postgresql://user:senha@host:5432/encerradigital_prod

# Gerado automaticamente pelo plugin Redis do Railway:
REDIS_URL=redis://default:senha@host:6379

# Cloudflare R2 (S3-compatível) — obter no dashboard do R2:
MINIO_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
MINIO_ACCESS_KEY=<r2_access_key_id>
MINIO_SECRET_KEY=<r2_secret_access_key>
MINIO_BUCKET=encerradigital-docs
MINIO_REGION=auto

# Gerar com: openssl rand -base64 32
JWT_SECRET=<segredo-forte-base64>
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Exatamente 32 caracteres — gerar com: openssl rand -hex 16
ENCRYPTION_KEY=<32-caracteres-exatos>

# URLs públicas dos frontends no Railway (preencher após criar os serviços)
FRONTEND_CLIENTE_URL=https://<frontend-cliente>.railway.app
FRONTEND_INTERNO_URL=https://<frontend-interno>.railway.app


# ── SERVIÇO: frontend-cliente ─────────────────────────────────────────────────
# Build:  pnpm install --frozen-lockfile && pnpm --filter ./frontend-cliente build
# Start:  pnpm --filter ./frontend-cliente exec next start

# URL pública do backend no Railway (sem barra final):
NEXT_PUBLIC_API_URL=https://<backend>.railway.app/api


# ── SERVIÇO: frontend-interno ─────────────────────────────────────────────────
# Build:  pnpm install --frozen-lockfile && pnpm --filter ./frontend-interno build
# Start:  pnpm --filter ./frontend-interno exec next start

# URL pública do backend no Railway (sem barra final):
NEXT_PUBLIC_API_URL=https://<backend>.railway.app/api

# Obrigatório em produção para NextAuth.js:
# Gerar com: openssl rand -base64 32
NEXTAUTH_SECRET=<segredo-forte-base64>

# URL canônica do frontend-interno (preencher após criar o serviço):
NEXTAUTH_URL=https://<frontend-interno>.railway.app


# ════════════════════════════════════════════════════════════════════════════
# CHECKLIST PÓS-DEPLOY (via Railway Shell no serviço backend)
# ════════════════════════════════════════════════════════════════════════════
# 1. npx prisma migrate deploy
# 2. npx tsx prisma/seed.ts
# 3. Testar: GET https://<backend>.railway.app/api/saude
#
# CREDENCIAIS DE TESTE — Frontend Interno (mock dev):
#   Matrícula: BRF0001  Senha: qualquer  → perfil: operador
#   Matrícula: BRF0002  Senha: qualquer  → perfil: supervisor
# ════════════════════════════════════════════════════════════════════════════
