generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StatusSolicitacao {
  PENDENTE
  EM_ANALISE
  CONCLUIDO
  CANCELADO
  REJEITADO
}

model Solicitacao {
  id                    String            @id @default(uuid())
  numeroProtocolo       String            @unique
  agencia               String            @db.VarChar(10)
  numeroConta           String            @db.VarChar(512)
  titularNome           String            @db.VarChar(512)
  motivoEncerramento    String?           @db.VarChar(100)
  status                StatusSolicitacao @default(PENDENTE)
  aceiteTermosVersao    String            @db.VarChar(20)
  aceiteTermosTimestamp DateTime
  ipOrigemMascarado     String?           @db.VarChar(20)
  criadoEm             DateTime          @default(now())
  atualizadoEm         DateTime          @updatedAt

  documentos       Documento[]

  @@index([status])
  @@index([agencia])
  @@map("solicitacoes")
}

enum TipoDocumento {
  TERMO_GERADO   // PDF gerado pelo sistema antes da assinatura
  TERMO_ASSINADO // PDF enviado pelo cliente após assinar via gov.br
}

model Documento {
  id            String        @id @default(uuid())
  solicitacaoId String
  tipo          TipoDocumento
  nomeOriginal  String        @db.VarChar(255)
  bucketMinio   String        @db.VarChar(100)
  chaveObjeto   String        @db.VarChar(512) // caminho no MinIO
  hashSha256    String        @db.VarChar(64) // integridade
  tamanhoBytes  Int
  mimeType      String        @db.VarChar(100)
  criadoEm     DateTime      @default(now())

  solicitacao Solicitacao @relation(fields: [solicitacaoId], references: [id])

  @@index([solicitacaoId])
  @@map("documentos")
}
